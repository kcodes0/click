{
  "name": "kcodes-games",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd apps/click && bun run dev",
    "dev:click": "cd apps/click && bun run dev",
    "typecheck": "cd apps/click && bun run typecheck",
    "deploy:click": "cd apps/click && bun run deploy",
    "db:migrate:local": "cd apps/click && bun run db:migrate:local",
    "db:migrate:remote": "cd apps/click && bun run db:migrate:remote"
  }
}
